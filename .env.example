# 抖音监控采集系统 - 环境变量示例
# 复制此文件为 .env 并填入实际值
# 启动时自动加载（无需修改 .bat/.sh）

# ===== HTTP 控制服务 =====
# HTTP_HOST=127.0.0.1
# HTTP_PORT=18911

# ===== 内存看门狗 =====
# MEM_WARN_MB=1024
# MEM_CRITICAL_MB=1536

# ===== 恢复策略 =====
# RECOVERY_MAX_PER_CATEGORY=3
# RECOVERY_COOLDOWN_MS=3000
# RECOVERY_WINDOW_MS=60000

# ===== 数据库 =====
# DB_PATH=./monitor.db

# ===== 抖音 Cookie（可选，用于跳过扫码） =====
# DOUYIN_COOKIE=odin_tt=xxx; msToken=yyy; ...

# ===== 邮件推送（也可在 UI 配置） =====
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_USER=your@qq.com
# SMTP_AUTH_CODE=xxxxxxxxxxxxxxxx

# ===== 企业微信 Webhook（也可在 UI 配置） =====
# WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx

# ===== 反检测 (Stealth Evasion) =====
# 抖音风控会检测 navigator.webdriver / canvas / webgl / audio 等 18 个维度
# 见 main/window.js STEALTH_SCRIPT
# STEALTH_ENABLED=true          # 是否启用反检测（生产建议开启）
# STEALTH_BLOCK_WEBDRIVER=true  # 隐藏 navigator.webdriver
# STEALTH_FAKE_PLUGINS=true     # 伪造 navigator.plugins
# STEALTH_NOISE_CANVAS=true     # Canvas 指纹噪声
# STEALTH_NOISE_AUDIO=true      # Audio 指纹噪声

# ===== 智能操作 (Smart Operations) =====
# 替代硬性 sleep，使用显式等待 + 自动重试
# 见 core/smartOps.js
# SMART_OPS_TIMEOUT_MS=8000         # 元素可点击等待超时
# SMART_OPS_RETRY=3                 # 失败重试次数
# SMART_OPS_RETRY_BACKOFF_MS=500    # 重试退避基数
# SMART_OPS_REQUIRE_STATE_CHANGE=true  # 点击后校验状态变化

# ===== 人类行为模拟 (Human Behavior) =====
# 模拟真人鼠标轨迹/打字节奏
# 见 core/humanBehavior.js
# HUMAN_BEZIER_ENABLED=true    # 启用 Bezier 曲线鼠标轨迹
# HUMAN_TYPE_TYPO_RATE=0.05    # 打字错字概率 5%
# HUMAN_TYPE_THINK_PAUSE=0.15  # 思考长停顿概率 15%

# ===== 调试 =====
# DEBUG_STEALTH=false          # 打印反检测注入日志
# DEBUG_SMART_OPS=false        # 打印智能操作决策日志
# DEBUG_PAGE_DUMP=false        # 自动 dump 页面结构到 logs/page-dumps/
